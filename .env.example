# PeoplesEyes – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# .env ist in .gitignore – niemals echte Werte committen.

# ─── Turbo ──────────────────────────────────────────────────────────────────
# Anonyme Nutzungsstatistiken deaktivieren (LOW-02 fix)
TURBO_TELEMETRY_DISABLED=1

# ─── GUN-Relays (optional) ──────────────────────────────────────────────────
# Komma-separierte Liste eigener GUN-Relay-URLs.
# Wenn nicht gesetzt, werden die öffentlichen Bootstrap-Relays verwendet.
# Empfohlen: eigenen Relay hosten (siehe infra/relay/README.md)
# VITE_GUN_RELAYS=https://relay.deine-domain.org/gun

# Privater Headscale-Relay im WireGuard-Mesh.
# Wird gegenüber öffentlichen Relays priorisiert und bei Nichterreichbarkeit
# automatisch übersprungen.
# VITE_GUN_HEADSCALE_RELAY=ws://100.64.0.1:8765/gun

# Optionale Tor-Proxy-URL für Umgebungen außerhalb des Browser-Sandbox-Modells.
# Im Browser ist primär Tor Browser oder Orbot als System-VPN relevant.
# VITE_GUN_PROXY=socks5://127.0.0.1:9050

# ─── Kiosk ──────────────────────────────────────────────────────────────────
# Standard-Profil-ID für den Kiosk-Dev-Server
# VITE_KIOSK_DEFAULT_PROFILE=beratungsstelle-berlin
