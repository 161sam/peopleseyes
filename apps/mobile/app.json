{
  "expo": {
    "name": "PeoplesEyes",
    "slug": "peopleseyes",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "peopleseyes",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f172a",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "org.peopleseyes.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "updates": {
        "enabled": true,
        "checkAutomatically": "ON_LOAD",
        "fallbackToCacheTimeout": 0
      }
    },
    "ios": {
      "bundleIdentifier": "org.peopleseyes.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Zum Aufnehmen von Beweisfotos und -videos.",
        "NSMicrophoneUsageDescription": "Zum Aufnehmen von Audio-Beweisen.",
        "NSLocationWhenInUseUsageDescription": "Zur anonymisierten Standortmeldung. Dein exakter Standort verl\u00e4sst das Ger\u00e4t nicht.",
        "NSPhotoLibraryUsageDescription": "Zum Speichern von Beweismaterial.",
        "NSPhotoLibraryAddUsageDescription": "Zum Speichern von Beweismaterial in der Fotos-App.",
        "ITSAppUsesNonExemptEncryption": true
      },
      "buildNumber": "1",
      "requireFullScreen": true,
      "usesAppleSignIn": false,
      "config": {
        "usesNonExemptEncryption": true
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": []
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Kamera f\u00fcr Beweisaufnahmen."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "F\u00fcr anonymisierte Meldungen. GPS wird nicht gespeichert.",
          "locationWhenInUsePermission": "F\u00fcr anonymisierte Meldungen. GPS wird nicht gespeichert."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png"
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-localization",
      [
        "expo-updates",
        {
          "enabled": true
        }
      ]
    ],
    "extra": {
      "gunRelays": [
        "https://gun-manhattan.herokuapp.com/gun",
        "https://peer.wallie.io/gun"
      ]
    }
  }
}